{
  "api_id": 123456,
  "api_hash": "your_api_hash_from_my.telegram.org",
  "jobs": [
    {
      "name": "hourly ping",
      "target": "@somechat_or_username",
      "mode": "interval",
      "every_hours": 3,
      "send_on_start": true,
      "send_style": "all",
      "messages": [
        "This message goes out every 3 hours."
      ]
    },
    {
      "name": "morning and evening",
      "target": "@friendusername",
      "mode": "times",
      "times": ["09:00", "9:30 pm"],
      "send_style": "rotate",
      "messages": [
        "Good morning!",
        "Good night!"
      ]
    }
  ]
}
